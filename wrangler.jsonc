{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "asignaciones",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
